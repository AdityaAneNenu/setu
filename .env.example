# ===================================================
# SETU PM - Environment Configuration (SECURITY UPDATED)
# ===================================================
# Copy this file and fill in your values:
#   - For Django: create .env in project root
#   - For Next.js: create frontend/.env.local
#   - For Mobile: Use EAS secrets (expo install expo-constants)
# ===================================================

# ─── CRITICAL SECURITY FIXES ─────────────────────────
# Mobile App Credentials (DO NOT hardcode in source!)
# Set these as EAS secrets or in app.config.js extra field:
FIREBASE_API_KEY=your-firebase-api-key-here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef123456
FIREBASE_MEASUREMENT_ID=G-ABCDEF1234
PRODUCTION_API_URL=https://setu.up.railway.app

# Cloudinary Credentials (move from source code)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset-name

# ─── DJANGO BACKEND CONFIGURATION ────────────────────
# Generate strong secret key: python -c \"from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())\"
SECRET_KEY=your-super-secret-key-minimum-50-characters-CHANGE-THIS
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,*.up.railway.app

# API Keys (optional but recommended)
GEMINI_API_KEY=your-gemini-api-key-for-voice-transcription
ASSEMBLYAI_API_KEY=your-assemblyai-key-for-backup-transcription

# ─── FIREBASE BACKEND INTEGRATION ────────────────────
# Django backend (.env)
# Download service account JSON from:
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# ─── RAILWAY DEPLOYMENT (Production) ─────────────────
# DATABASE_URL is auto-set by Railway when you add PostgreSQL
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Firebase credentials as JSON string (for Railway/production)
# Paste the ENTIRE contents of firebase-service-account.json here as one line:
# FIREBASE_CREDENTIALS_JSON={\"type\":\"service_account\",\"project_id\":\"...\"}
FIREBASE_CREDENTIALS_JSON=
