{
  // Django template settings
  "files.associations": {
    "**/*.html": "html",
    "**/templates/**/*.html": "django-html",
    "**/templates/**": "django-txt",
    "**/requirements{/**,*}.{txt,in}": "pip-requirements"
  },
  
  // Disable CSS/JS validation inside Django templates
  "css.validate": false,
  "javascript.validate.enable": false,
  
  // HTML settings for Django templates
  "html.format.templating": true,
  "html.format.wrapLineLength": 0,
  
  // Emmet for Django templates
  "emmet.includeLanguages": {
    "django-html": "html"
  },
  
  // Disable error squiggles for Django template syntax
  "html.validate.scripts": false,
  "html.validate.styles": false,
  
  // Python settings
  "python.languageServer": "Pylance",
  "[python]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  
  // Django-specific Python paths
  "python.analysis.extraPaths": [
    "${workspaceFolder}",
    "${workspaceFolder}/core"
  ],
  
  // Auto-detect Django settings
  "python.analysis.diagnosticMode": "workspace",
  
  // Exclude directories from search/watch
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/node_modules": true
  },
  
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/media": true,
    "**/static/admin": true,
    "**/__pycache__": true,
    "**/*.pyc": true
  },
  
  // Editor settings
  "editor.formatOnSave": false,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  
  // Terminal settings
  "terminal.integrated.env.windows": {
    "DJANGO_SETTINGS_MODULE": "config.settings"
  }
}
